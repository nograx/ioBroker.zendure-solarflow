{
  "name": "iobroker.zendure-solarflow",
  "version": "4.0.4",
  "description": "zendure-solarflow",
  "author": {
    "name": "Peter",
    "email": "peter.frommert@outlook.com"
  },
  "license": "GPL-3.0-only",
  "homepage": "https://github.com/nograx/ioBroker.zendure-solarflow",
  "keywords": [
    "Zendure",
    "Solarflow",
    "ioBroker"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nograx/ioBroker.zendure-solarflow.git"
  },
  "engines": {
    "node": ">= 22"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "@mui/styles": "^6.4.8",
    "axios": "^1.9.0",
    "mqtt": "^5.14.1"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/adapter-react-v5": "^8.0.13",
    "@iobroker/testing": "^5.2.2",
    "@mui/material": "^6.5.0",
    "@tsconfig/node16": "^16.1.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^16.18.57",
    "@types/node-schedule": "^2.1.6",
    "@types/proxyquire": "^1.3.30",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.37.5",
    "mocha": "^11.7.5",
    "prettier": "^3.6.2",
    "proxyquire": "^2.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^5.0.5",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3"
  },
  "main": "build/main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "admin/build/",
    "build/",
    "www/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rimraf build admin/build",
    "build": "build-adapter all",
    "watch": "build-adapter all --watch",
    "prebuild:ts": "rimraf build",
    "build:ts": "build-adapter ts",
    "watch:ts": "build-adapter ts --watch",
    "prebuild:react": "rimraf admin/build",
    "build:react": "build-adapter react",
    "watch:react": "build-adapter react --watch",
    "test:ts": "mocha --config test/mocharc.custom.json src/**/*.test.ts",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:ts && npm run test:package",
    "check": "tsc --noEmit && tsc --noEmit -p admin/tsconfig.json",
    "lint": "eslint --ext .ts,.tsx src/ admin/src/",
    "translate": "translate-adapter",
    "release": "release-script"
  },
  "bugs": {
    "url": "https://github.com/nograx/ioBroker.zendure-solarflow/issues"
  },
  "readmeFilename": "README.md"
}
